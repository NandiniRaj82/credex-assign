# Environment Variables — StackLens
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ---- Supabase ----
# Your Supabase project URL (from Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — safe to expose client-side (RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Anthropic ----
# Used for the AI-generated summary in the results page
ANTHROPIC_API_KEY=sk-ant-...

# ---- Resend ----
# For transactional audit confirmation emails
RESEND_API_KEY=re_...

# ---- hCaptcha ----
# Site key is safe to expose client-side
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# hCaptcha secret — SERVER SIDE ONLY
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# ---- App ----
# Your deployed URL (used for OG tags and shareable links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# From email address for Resend (must be from a verified domain)
RESEND_FROM_EMAIL=audit@yourdomain.com
